@page "/"
@using ConcertTrackerBlazorHybridApp.Services
@using ConcertTrackerBlazorHybridApp.DataTransferObjects
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory
@inject IConcertService ConcertService

<h1>Concert Tracker</h1>

Welcome to your new Concert Tracker App.

@* <ul class="list-unstyled">
    @foreach (var concert in concert)
    {
        <li>
            <input type="checkbox" @bind="concert.Attended" />
            <input @bind="concert.Artist" />
        </li>
    }
</ul> *@
<Div>
    <input placeholder="Artist" @bind="newArtist" />
    <input placeholder="Venue" @bind="newVenue" />
    <input placeholder="City" list="city-suggestions" @bind="newCity" @oninput="OnCityInput" />
    <datalist id="city-suggestions">
        @foreach (var city in citySuggestions)
        {
            <option value="@city" />
        }
    </datalist>
    <DateInput TValue="DateTime?" @bind-Value="@concertDate" />
    <Switch TValue="bool" @bind-Value="@attended" Disabled="@IsFuture">Attended</Switch>
    @if (attended)
    {
        <Rating @key="ratingKey" Color="Color.Primary" @bind-SelectedValue="@rating" MaxValue="5" GetTooltip="@GetTooltip" />
    }
    <Button Color="Color.Primary" Clicked="AddConcert">Add Concert</Button>
</Div>

<Alert Color="Color.Success" @bind-Visible="@visible">
    <AlertDescription>
        Successfully Added A Concert
    </AlertDescription>
    <CloseButton />
</Alert>

<div>
    <h2>Ready to Rate?</h2>
    @foreach (var concert in ConcertService.ToBeRated())
    {
        <div class="col">
            <Card>
                <CardBody>
                    <CardTitle Size="HeadingSize.Is5">@concert.Artist</CardTitle>
                    <CardText>@concert.Venue</CardText>
                    <CardText>@concert.City</CardText>
                    <CardText>@concert.Date?.ToShortDateString()</CardText>                    
                    <Rating @key="ratingKey" Color="Color.Primary" @bind-SelectedValue="@rating" MaxValue="5" GetTooltip="@GetTooltip" />             
                </CardBody>
                <Button Color="Color.Primary" Clicked="() => AddRating(concert, rating)">Update Concert</Button>
            </Card>
            @if (string.IsNullOrEmpty(rating.ToString()))
            {
                <p>Please rate the concert</p>
            }
        </div>
    }
</div>

@code {
    public IReadOnlyList<ConcertDto> concert => ConcertService.GetAll();
    public string? newCity;
    public string? newArtist;
    public string? newVenue;
    public DateTime? concertDate;
    public bool attended;
    public int rating;
    private int ratingKey;
    private List<string> citySuggestions = new();
    private bool visible = false;

    private async Task OnCityInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        newCity = value;

        if (value.Length < 2)
        {
            citySuggestions.Clear();
            return;
        }

        try
        {
            var http = HttpClientFactory.CreateClient("nominatim");
            var request = new HttpRequestMessage(HttpMethod.Get,
                $"/search?q={Uri.EscapeDataString(value)}&featuretype=city&format=json&limit=8&addressdetails=0");
            request.Headers.Add("User-Agent", "ConcertTrackerApp/1.0");
            var response = await http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                using var doc = JsonDocument.Parse(json);
                citySuggestions = doc.RootElement.EnumerateArray()
                    .Select(e => e.GetProperty("display_name").GetString() ?? string.Empty)
                    .Where(s => !string.IsNullOrEmpty(s))
                    .ToList();
            }
        }
        catch
        {
            citySuggestions.Clear();
        }
    }

    private bool IsFuture => concertDate.HasValue && concertDate.Value.Date > DateTime.Today;

    RatingTooltip GetTooltip(int value)
    {
        if (value == 1)
            return new RatingTooltip("Very bad");
        else if (value == 2)
            return new RatingTooltip("Bad", TooltipPlacement.Bottom);
        else if (value == 3)
            return new RatingTooltip("Fair");
        else if (value == 4)
            return new RatingTooltip("Good", TooltipPlacement.Top, false, false);
        else if (value == 5)
            return new RatingTooltip("Very good");
        
        return null;
    }

    private void AddConcert()
    {
        if (!string.IsNullOrWhiteSpace(newArtist))
        {
            int? validRating = (attended && rating >= 1 && rating <= 5) ? rating : null;

            ConcertService.Add(new ConcertDto { Artist = newArtist, Venue = newVenue, City = newCity, Date = concertDate ?? DateTime.Now, Attended = attended, Rating = validRating });
            newArtist = string.Empty;
            newVenue = string.Empty;
            newCity = string.Empty;
            concertDate = null;
            attended = false;
            rating = 0;
            ratingKey++;
            visible = true;
        }
    }

    private void AddRating(ConcertDto concert, int rating)
    {
        if (rating >= 1 && rating <= 5)
        {
            concert.Rating = rating;
            ConcertService.AddRating(concert, rating);
            ratingKey++;
        }
        else 
        {
            
        }
    }
}