@page "/upcoming"
@using ConcertTrackerBlazorHybridApp.Services
@inject ConcertService ConcertService

<h1>Upcoming Concerts</h1>

<p>Here are your next gigs</p>

@if (!ConcertService.GetUpcoming().Any())
{
    <p>No upcoming concerts yet. Add concerts on the Home page.</p>
}

<div class="row row-cols-1 row-cols-md-3 g-3">
    @foreach (var concert in ConcertService.GetUpcoming())
    {
        <div class="col">
            <Card>
                <CardBody>
                    <CardTitle Size="HeadingSize.Is5">@concert.Artist</CardTitle>
                    <CardTitle Size="HeadingSize.Is6">@concert.Venue</CardTitle>
                    <CardText>@concert.City</CardText>
                    <CardText>@concert.Date?.ToShortDateString()</CardText>
                    <Switch TValue="bool"
                            Disabled="@IsFuture(concert.Date ?? DateTime.MinValue)"
                            GetTooltip="@GetTooltip">Attended
                    </Switch>
                    @if (concert.Attended)
                    {
                        
                    }
                </CardBody>
            </Card>
        </div>

        RatingTooltip GetTooltip(int value)
        {
            if (value == 1)
                return new RatingTooltip("Very bad");
            else if (value == 2)
                return new RatingTooltip("Bad", TooltipPlacement.Bottom);
            else if (value == 3)
                return new RatingTooltip("Fair");
            else if (value == 4)
                return new RatingTooltip("Good", TooltipPlacement.Top, false, false);
            else if (value == 5)
                return new RatingTooltip("Very good");

            return null;
        }
    }
</div>

@code {
    private static bool IsFuture(DateTime concertDate)
    {
        return concertDate.Date > DateTime.Today;
    }
}
